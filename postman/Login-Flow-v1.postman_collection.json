{
  "info": {
    "name": "Swampurna Login Flow APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Register Customer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"name\": \"Aditi Sharma\",\n  \"phone\": \"+919999999999\",\n  \"role\": \"customer\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "2. Resend Register OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register/otp/resend",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register",
            "otp",
            "resend"
          ]
        }
      }
    },
    {
      "name": "3. Verify Register OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"1234\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register/otp/verify",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register",
            "otp",
            "verify"
          ]
        }
      }
    },
    {
      "name": "4. Send Login OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"purpose\": \"login\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/otp/send",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "otp",
            "send"
          ]
        }
      }
    },
    {
      "name": "5. Resend Login OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"purpose\": \"login\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/otp/resend",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "otp",
            "resend"
          ]
        }
      }
    },
    {
      "name": "6. Verify Login OTP (returns token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp\": \"1234\",\n  \"purpose\": \"login\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/otp/verify",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "otp",
            "verify"
          ]
        }
      }
    },
    {
      "name": "7. Login With PIN",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"pin\": \"1234\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login/pin",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login",
            "pin"
          ]
        }
      }
    },
    {
      "name": "8. Set PIN",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pin\": \"1234\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/pin/set",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "pin",
            "set"
          ]
        }
      }
    },
    {
      "name": "9. Verify PIN",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pin\": \"1234\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/pin/verify",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "pin",
            "verify"
          ]
        }
      }
    },
    {
      "name": "10. Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "11. Get Customer Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/customers/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "customers",
            "profile"
          ]
        }
      }
    },
    {
      "name": "12. Update Customer Profile",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Aditi Sharma\",\n  \"phone\": \"+919999999999\",\n  \"onboarding_source\": \"instagram_or_facebook\",\n  \"birth_year\": 2000,\n  \"pregnancy_status\": \"no_i_am_here_to_understand_my_body\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/customers/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "customers",
            "profile"
          ]
        }
      }
    },
    {
      "name": "13. Save Onboarding Step",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"step\": \"source\",\n  \"onboarding_source\": \"Instagram or Facebook\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/customers/onboarding",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "customers",
            "onboarding"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://swampurna-final-production.up.railway.app"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ]
}