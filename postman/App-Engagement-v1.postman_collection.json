{
  "info": {
    "_postman_id": "60fd25c2-cf9a-4dd6-bef5-3f42e12df357",
    "name": "Swampurna App Engagement APIs v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Report a problem, notification settings, and cycle snaps APIs."
  },
  "item": [
    {
      "name": "Auth - Login (Get Token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.token) pm.collectionVariables.set('token', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Notification Settings - Get",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/notifications/settings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "notifications",
            "settings"
          ]
        }
      }
    },
    {
      "name": "Notification Settings - Update",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"period_reminder_enabled\": true,\n  \"ovulation_reminder_enabled\": true,\n  \"daily_insights_enabled\": true,\n  \"daily_period_reminder_enabled\": false,\n  \"app_updates_enabled\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/notifications/settings",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "notifications",
            "settings"
          ]
        }
      }
    },
    {
      "name": "Support - Submit Report (with optional file)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "issue_types",
              "value": "[\"app bug\",\"data issue\"]",
              "type": "text"
            },
            {
              "key": "details",
              "value": "The app crashes on tracker screen.",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/support/reports",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "support",
            "reports"
          ]
        }
      }
    },
    {
      "name": "Support - My Reports",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/support/reports/my?limit={{limit}}&offset={{offset}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "support",
            "reports",
            "my"
          ],
          "query": [
            {
              "key": "limit",
              "value": "{{limit}}"
            },
            {
              "key": "offset",
              "value": "{{offset}}"
            }
          ]
        }
      }
    },
    {
      "name": "Cycle Snaps - Upload Media",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/cycle-snaps/media/upload",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "cycle-snaps",
            "media",
            "upload"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json.url) pm.collectionVariables.set('snapMediaUrl', json.url);",
              "if (json.media_type) pm.collectionVariables.set('snapMediaType', json.media_type);"
            ]
          }
        }
      ]
    },
    {
      "name": "Cycle Snaps - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"My first cycle snap\",\n  \"description\": \"Sharing a menstrual health awareness creative\",\n  \"media_url\": \"{{snapMediaUrl}}\",\n  \"media_type\": \"{{snapMediaType}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/cycle-snaps",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "cycle-snaps"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "if (json?.data?.id) pm.collectionVariables.set('snapId', json.data.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Cycle Snaps - Public Feed (approved)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/cycle-snaps?limit={{limit}}&offset={{offset}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "cycle-snaps"
          ],
          "query": [
            {
              "key": "limit",
              "value": "{{limit}}"
            },
            {
              "key": "offset",
              "value": "{{offset}}"
            }
          ]
        }
      }
    },
    {
      "name": "Cycle Snaps - My Submissions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/cycle-snaps?mine=true&limit={{limit}}&offset={{offset}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "cycle-snaps"
          ],
          "query": [
            {
              "key": "mine",
              "value": "true"
            },
            {
              "key": "limit",
              "value": "{{limit}}"
            },
            {
              "key": "offset",
              "value": "{{offset}}"
            }
          ]
        }
      }
    },
    {
      "name": "Cycle Snaps - Detail",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/cycle-snaps/{{snapId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "cycle-snaps",
            "{{snapId}}"
          ]
        }
      }
    },
    {
      "name": "Cycle Snaps - Admin Approve/Reject",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"approved\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/cycle-snaps/{{snapId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "cycle-snaps",
            "{{snapId}}",
            "status"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "email",
      "value": "customer@example.com"
    },
    {
      "key": "password",
      "value": "customer123"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "limit",
      "value": "20"
    },
    {
      "key": "offset",
      "value": "0"
    },
    {
      "key": "snapMediaUrl",
      "value": ""
    },
    {
      "key": "snapMediaType",
      "value": "image"
    },
    {
      "key": "snapId",
      "value": ""
    }
  ]
}