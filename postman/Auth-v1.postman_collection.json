        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/pin/verify",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "pin",
            "verify"
          ]
        },
        "description": "Verify current user's PIN."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test(\"PIN verified\", function () {",
              "  pm.expect(json.verified).to.eql(true);",
