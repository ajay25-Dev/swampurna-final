{
  "info": {
    "_postman_id": "9c826963-fce2-4fd1-a0a0-bafebc7a7bb0",
    "name": "Swampurna Auth v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Ready-to-import collection for /api/v1/auth register, login, profile and PIN APIs."
  },
  "item": [
    {
      "name": "1. Register Customer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer1@test.com\",\n  \"role\": \"customer\",\n  \"name\": \"Test Customer\",\n  \"phone\": \"9876543210\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        },
        "description": "Create user without password (OTP-first flow). Password optional."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test(\"Verification required\", function () {",
              "  pm.expect(json.requires_verification).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "1A. Resend Register OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register/otp/resend",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register",
            "otp",
            "resend"
          ]
        }
      },
      "response": []
    },
    {
      "name": "1B. Verify Register OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register/otp/verify",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register",
            "otp",
            "verify"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "if (json.token) { pm.collectionVariables.set('token', json.token); }"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Password Login (Disabled)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"Pass@123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        },
        "description": "Password login is disabled. Expected HTTP 410."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 410', function () {",
              "  pm.response.to.have.status(410);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2A. Send OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"purpose\": \"login\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/otp/send",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "otp",
            "send"
          ]
        },
        "description": "Send 4-digit OTP to email and save in otp_verify table."
      },
      "response": []
    },
    {
      "name": "2A1. Resend OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"purpose\": \"login\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/otp/resend",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "otp",
            "resend"
          ]
        },
        "description": "Resend OTP (cooldown applies)."
      },
      "response": []
    },
    {
      "name": "2B. Verify OTP (Login)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\",\n  \"purpose\": \"login\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/otp/verify",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "otp",
            "verify"
          ]
        },
        "description": "Verify OTP and receive JWT token."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "if (json.token) { pm.collectionVariables.set('token', json.token); }"
            ]
          }
        }
      ]
    },
    {
      "name": "2C. Login With PIN",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"pin\": \"1234\"\n}"
