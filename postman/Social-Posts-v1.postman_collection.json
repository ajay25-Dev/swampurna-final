{
  "info": {
    "_postman_id": "4aaef2f0-e6a5-4f68-9448-31f5fe4bc93d",
    "name": "Swampurna Social Posts APIs v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Ready-to-import collection for social post APIs (create post, feed, like, comments, media upload)."
  },
  "item": [
    {
      "name": "Auth - Login (Get Token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "if (json.token) {",
              "  pm.collectionVariables.set(\"token\", json.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Posts - Upload Image",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/posts/media/upload",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "posts",
            "media",
            "upload"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "if (json.url) {",
              "  pm.collectionVariables.set(\"postImageUrl\", json.url);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Posts - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"My first social post\",\n  \"content\": \"Periods are powerful, not shameful.\",\n  \"image_url\": \"{{postImageUrl}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/posts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "posts"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "if (json.data && json.data.id) {",
              "  pm.collectionVariables.set(\"postId\", json.data.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Posts - Feed List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/posts?limit=20&offset=0",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "posts"
          ],
          "query": [
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "if (json.data && json.data.length > 0 && json.data[0].id) {",
              "  pm.collectionVariables.set(\"postId\", json.data[0].id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Posts - Detail",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/posts/{{postId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "posts",
            "{{postId}}"
          ]
        }
      }
    },
    {
      "name": "Posts - Toggle Like",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/posts/{{postId}}/like",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "posts",
            "{{postId}}",
            "like"
          ]
        }
      }
    },
    {
      "name": "Comments - List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/posts/{{postId}}/comments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "posts",
            "{{postId}}",
            "comments"
          ]
        }
      }
    },
    {
      "name": "Comments - Add",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"Great post! Thanks for sharing.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/posts/{{postId}}/comments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "posts",
            "{{postId}}",
            "comments"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "email",
      "value": "customer@example.com"
    },
    {
      "key": "password",
      "value": "customer123"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "postImageUrl",
      "value": ""
    },
    {
      "key": "postId",
      "value": ""
    }
  ]
}
